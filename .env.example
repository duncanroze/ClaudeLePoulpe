# Connexion Postgres (Neon) — URL pooler recommandée pour Vercel
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# The Odds API — clé gratuite (500 crédits/mois) : https://the-odds-api.com/
# Sert pour les cotes 1N2, la liste des matchs et les scores finaux réels.
# Tout est caché en BDD : les clics des visiteurs ne consomment pas le quota.
ODDS_API_KEY=xxxxxxxxxxxxxxxx

# football-data.org — token gratuit : https://www.football-data.org/client/register
# Sert UNIQUEMENT à afficher le score des tirs au but des matchs à élimination
# directe (The Odds API ne les fournit pas). Optionnel : sans token, le site
# fonctionne comme avant, sans l'affichage des pénos. FOOTBALL_DATA_COMPETITION
# permet de surcharger le code compétition (défaut : WC = Coupe du monde).
FOOTBALL_DATA_TOKEN=xxxxxxxxxxxxxxxx
# FOOTBALL_DATA_COMPETITION=WC
